{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["step_id", "status", "data"],
  "properties": {
    "step_id": {
      "type": "string",
      "description": "Step identifier"
    },
    "status": {
      "type": "string",
      "enum": ["success", "warning", "failed"],
      "description": "Execution status"
    },
    "data": {
      "type": "object",
      "description": "Step-specific output data"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-fatal warning messages"
    },
    "notes": {
      "type": "string",
      "description": "Additional agent notes"
    },
    "rubric_scores": {
      "type": "object",
      "description": "Self-evaluation scores per dimension"
    },
    "critical_failures": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of critical failures"
    }
  }
}
